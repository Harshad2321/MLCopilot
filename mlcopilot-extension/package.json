{
    "name": "mlcopilot",
    "displayName": "MLCopilot",
    "description": "Real-Time ML Training Monitor – detect failures, get root cause analysis, and fix training live from VS Code.",
    "version": "0.2.0",
    "publisher": "mlcopilot",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Harshad2321/MLCopilot"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Machine Learning",
        "Data Science",
        "Other"
    ],
    "keywords": [
        "machine-learning",
        "deep-learning",
        "pytorch",
        "training-monitor",
        "ml-ops"
    ],
    "icon": "icon.png",
    "activationEvents": [
        "onLanguage:python"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "mlcopilot.openDashboard",
                "title": "MLCopilot: Open Dashboard"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.3.0",
        "@vscode/vsce": "^3.0.0"
    }
}
